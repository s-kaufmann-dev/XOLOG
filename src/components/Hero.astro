---
import { Image } from 'astro:assets';
import heroImage from '../assets/hero.png';
---

<section id="hero" class="relative h-screen flex flex-col justify-end overflow-hidden">
	<div class="absolute inset-0 z-0">
		<Image 
			src={heroImage} 
			alt="XOLOG DJ Duo performing" 
			class="w-full h-full object-cover grayscale brightness-[0.3]" 
		/>
		<div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent"></div>
	</div>

	<div class="relative z-10 section-padding pb-32">
		<h1 class="text-[12vw] leading-[0.85] font-black tracking-tighter uppercase text-white animate-fade-in">
			XO<br />LOG
		</h1>
		<div class="mt-8 flex flex-col md:flex-row gap-8 items-start md:items-center animate-fade-in" style="animation-delay: 0.2s;">
			<p class="text-xl md:text-2xl text-white/50 max-w-lg leading-tight uppercase font-light">
				Artistic Minimalism. <br />Deep Nightlife Aesthetics.
			</p>
			<a href="#contact" class="btn-primary">Book Now</a>
		</div>
	</div>
</section>
