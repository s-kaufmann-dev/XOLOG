---
import { Image } from 'astro:assets';
import liveSet from '../assets/live-set.png';
---

<section id="media" class="section-padding relative overflow-hidden">
	<div class="absolute inset-0 z-0">
		<Image 
			src={liveSet} 
			alt="XOLOG Live Set Crowd" 
			class="w-full h-full object-cover grayscale brightness-[0.2]" 
		/>
		<div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-transparent to-[#0a0a0a]"></div>
	</div>

	<div class="relative z-10">
		<h2 class="text-4xl md:text-6xl font-black mb-16 text-center">Selected Sets</h2>
		
		<div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-6xl mx-auto">
			<div class="glass-card p-8 flex flex-col justify-between aspect-video group cursor-pointer hover:border-white/30 transition-all duration-500">
				<div>
					<span class="text-xs uppercase tracking-[0.3em] text-white/40">Mix Series</span>
					<h3 class="text-2xl mt-4">Midnight Rituals - 001</h3>
				</div>
				<div class="flex items-center gap-4 text-sm font-bold uppercase tracking-widest text-white/60 group-hover:text-white transition-colors">
					Listen on SoundCloud 
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="translate-x-0 group-hover:translate-x-2 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
				</div>
			</div>

			<div class="glass-card p-8 flex flex-col justify-between aspect-video group cursor-pointer hover:border-white/30 transition-all duration-500">
				<div>
					<span class="text-xs uppercase tracking-[0.3em] text-white/40">Live Recording</span>
					<h3 class="text-2xl mt-4">Live at Warehouse 7</h3>
				</div>
				<div class="flex items-center gap-4 text-sm font-bold uppercase tracking-widest text-white/60 group-hover:text-white transition-colors">
					Listen on Mixcloud 
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="translate-x-0 group-hover:translate-x-2 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
				</div>
			</div>
		</div>

		<div class="mt-24 text-center">
			<p class="text-white/40 uppercase tracking-widest text-sm mb-8">Follow for more</p>
			<div class="flex justify-center gap-8 text-2xl">
				<a href="#" class="hover:text-white/60 transition-colors">SC</a>
				<a href="#" class="hover:text-white/60 transition-colors">IG</a>
				<a href="#" class="hover:text-white/60 transition-colors">SP</a>
			</div>
		</div>
	</div>
</section>
