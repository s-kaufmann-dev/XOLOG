---
---

<section id="contact" class="section-padding bg-[#0a0a0a] text-white border-t border-white/5">
	<div class="max-w-4xl mx-auto">
		<h2 class="text-4xl md:text-8xl font-black mb-16 leading-none">Book<br />XOLOG</h2>
		
		<form class="space-y-12">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
				<div class="space-y-4">
					<label class="uppercase text-[10px] tracking-[0.4em] font-bold text-white/40">Full Name</label>
					<input type="text" placeholder="Your Name" class="w-full bg-transparent border-b border-white/10 py-4 focus:outline-none focus:border-white transition-colors placeholder:text-white/20" />
				</div>
				<div class="space-y-4">
					<label class="uppercase text-[10px] tracking-[0.4em] font-bold text-white/40">Email</label>
					<input type="email" placeholder="Your Email" class="w-full bg-transparent border-b border-white/10 py-4 focus:outline-none focus:border-white transition-colors placeholder:text-white/20" />
				</div>
			</div>
			
			<div class="space-y-4">
				<label class="uppercase text-[10px] tracking-[0.4em] font-bold text-white/40">Event Details</label>
				<input type="text" placeholder="Location, Date, Type of Event" class="w-full bg-transparent border-b border-white/10 py-4 focus:outline-none focus:border-white transition-colors placeholder:text-white/20" />
			</div>

			<div class="space-y-4">
				<label class="uppercase text-[10px] tracking-[0.4em] font-bold text-white/40">Message</label>
				<textarea rows="4" placeholder="How can we help?" class="w-full bg-transparent border-b border-white/10 py-4 focus:outline-none focus:border-white transition-colors resize-none placeholder:text-white/20"></textarea>
			</div>

			<button type="submit" class="bg-white text-black px-12 py-5 rounded-full uppercase tracking-[0.3em] font-bold text-sm hover:bg-white/90 transition-all transform hover:scale-105">
				Send Inquiry
			</button>
		</form>
	</div>
</section>
