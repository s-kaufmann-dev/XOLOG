---
import { Image } from 'astro:assets';
import pressKit from '../assets/press-kit-v3.png';
---

<section id="about" class="section-padding bg-[#0a0a0a] border-t border-white/5">
	<div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
		<div class="order-2 lg:order-1">
			<h2 class="text-4xl md:text-6xl font-black mb-8 text-white">The Artist</h2>
			<div class="space-y-6 text-xl text-white/50 leading-relaxed font-light">
				<p>
					Born from the shadows of the Berlin underground, XOLOG is a producer and DJ duo dedicated to the purity of sound and the intensity of the night.
				</p>
				<p>
					Their style is characterized by a minimalist approach to production—each beat, each note carefully chosen to create an immersive, hypnotic experience on the dancefloor.
				</p>
				<p>
					XOLOG is more than just music; it is an artistic exploration of the symbiosis between light, shadow, and sound.
				</p>
			</div>
		</div>
		<div class="order-1 lg:order-2 flex justify-center lg:justify-end">
			<div class="relative w-full aspect-[3/4] max-w-md overflow-hidden rounded-2xl grayscale brightness-75 hover:grayscale-0 transition-all duration-700">
				<Image 
					src={pressKit} 
					alt="XOLOG Press Kit Photo" 
					class="w-full h-full object-cover" 
				/>
				<div class="absolute inset-0 border border-white/10 rounded-2xl pointer-events-none"></div>
			</div>
		</div>
	</div>
</section>
