---
const currentYear = new Date().getFullYear();
---

<footer class="py-24 px-6 md:px-12 bg-[#0a0a0a] border-t border-white/5">
	<div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-16">
		<div class="space-y-4">
			<h4 class="text-4xl font-black">XOLOG</h4>
			<p class="text-white/30 max-w-xs uppercase tracking-widest text-[10px] leading-relaxed">
				Minimalist Sound. <br />Maximum Impact. <br />Global Booking.
			</p>
		</div>
		
		<div class="flex flex-wrap gap-12 text-[10px] uppercase tracking-[0.3em] font-bold text-white/40">
			<a href="#" class="hover:text-white transition-colors">Instagram</a>
			<a href="#" class="hover:text-white transition-colors">SoundCloud</a>
			<a href="#" class="hover:text-white transition-colors">Tiktok</a>
			<a href="#" class="hover:text-white transition-colors">Imprint</a>
		</div>

		<div class="text-[10px] uppercase tracking-[0.3em] font-bold text-white/20">
			&copy; {currentYear} XOLOG. All Rights Reserved.
		</div>
	</div>
</footer>
